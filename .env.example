# NotificasHub — base del hub (sin barra final). Debe existir POST {NOTIFICASHUB_URL}/api/whatsapp/send
NOTIFICASHUB_URL=
# Mismo id que el documento tenants/planesdeahorro en Firestore del hub
NOTIFICASHUB_TENANT_ID=planesdeahorro
# Mismo valor que internalSecret de ese tenant (no commitear el valor real)
NOTIFICASHUB_INBOUND_SECRET=
# Si el tenant del hub usa internalAuthHeader distinto de x-internal-token, definir el nombre aquí
# NOTIFICASHUB_INBOUND_AUTH_HEADER=x-internal-token
# Solo si el envío al hub debe usar otro secret (por defecto se usa NOTIFICASHUB_INBOUND_SECRET)
# NOTIFICASHUB_SEND_SECRET=
